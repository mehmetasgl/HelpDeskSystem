@{
    ViewData["Title"] = "Giriş Türü Seçin";
}

<div class="container">
    <div class="row justify-content-center mt-5">
        <div class="col-md-10">
            <h2 class="text-center mb-5">Mini HelpDesk'e Hoşgeldiniz</h2>
            
            <div class="alert alert-info text-center mb-4">
                <i class="bi bi-info-circle"></i>
                <strong>Önemli!</strong> Lütfen hesap türünüze uygun giriş yöntemini seçin. 
                Admin hesapları yalnızca admin girişinden, kullanıcı hesapları yalnızca kullanıcı girişinden erişebilir.
            </div>
            
            <div class="row g-4">
                <!-- Kullanıcı Girişi -->
                <div class="col-md-6">
                    <div class="card shadow-lg h-100 border-primary">
                        <div class="card-body text-center p-5">
                            <div class="mb-4">
                                <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor" class="bi bi-person-circle text-primary" viewBox="0 0 16 16">
                                    <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
                                    <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z"/>
                                </svg>
                            </div>
                            <h3 class="card-title mb-3">Kullanıcı Girişi</h3>
                            <p class="card-text text-muted mb-4">
                                Destek talebi oluşturmak ve takip etmek için giriş yapın
                            </p>
                            <a asp-action="Login" asp-route-type="user" class="btn btn-primary btn-lg w-100 mb-2">
                                Kullanıcı Girişi
                            </a>
                            <a asp-action="Register" class="btn btn-outline-primary w-100">
                                Kayıt Ol
                            </a>
                            <div class="mt-3">
                                <small class="text-muted">
                                    Standart kullanıcı hesapları için
                                </small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Admin Girişi -->
                <div class="col-md-6">
                    <div class="card shadow-lg h-100 border-danger">
                        <div class="card-body text-center p-5">
                            <div class="mb-4">
                                <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor" class="bi bi-shield-lock text-danger" viewBox="0 0 16 16">
                                    <path d="M5.338 1.59a61.44 61.44 0 0 0-2.837.856.481.481 0 0 0-.328.39c-.554 4.157.726 7.19 2.253 9.188a10.725 10.725 0 0 0 2.287 2.233c.346.244.652.42.893.533.12.057.218.095.293.118a.55.55 0 0 0 .101.025.615.615 0 0 0 .1-.025c.076-.023.174-.061.294-.118.24-.113.547-.29.893-.533a10.726 10.726 0 0 0 2.287-2.233c1.527-1.997 2.807-5.031 2.253-9.188a.48.48 0 0 0-.328-.39c-.651-.213-1.75-.56-2.837-.855C9.552 1.29 8.531 1.067 8 1.067c-.53 0-1.552.223-2.662.524zM5.072.56C6.157.265 7.31 0 8 0s1.843.265 2.928.56c1.11.3 2.229.655 2.887.87a1.54 1.54 0 0 1 1.044 1.262c.596 4.477-.787 7.795-2.465 9.99a11.775 11.775 0 0 1-2.517 2.453 7.159 7.159 0 0 1-1.048.625c-.28.132-.581.24-.829.24s-.548-.108-.829-.24a7.158 7.158 0 0 1-1.048-.625 11.777 11.777 0 0 1-2.517-2.453C1.928 10.487.545 7.169 1.141 2.692A1.54 1.54 0 0 1 2.185 1.43 62.456 62.456 0 0 1 5.072.56z"/>
                                    <path d="M9.5 6.5a1.5 1.5 0 0 1-1 1.415l.385 1.99a.5.5 0 0 1-.491.595h-.788a.5.5 0 0 1-.49-.595l.384-1.99a1.5 1.5 0 1 1 2-1.415z"/>
                                </svg>
                            </div>
                            <h3 class="card-title mb-3">Admin Girişi</h3>
                            <p class="card-text text-muted mb-4">
                                Sistem yönetimi ve destek taleplerini yönetmek için giriş yapın
                            </p>
                            <a asp-action="Login" asp-route-type="admin" class="btn btn-danger btn-lg w-100">
                                Admin Girişi
                            </a>
                            <div class="mt-3">
                                <small class="text-muted">
                                    <strong>Test Admin:</strong><br>
                                    admin@minihelpdesk.com / Admin123
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .card:hover {
        transform: translateY(-10px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.2) !important;
    }
</style>