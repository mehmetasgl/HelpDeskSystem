@model MiniHelpDesk.ViewModels.AdminTicketListViewModel

@{
    ViewData["Title"] = "Ticket Yönetimi";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container-fluid">
    <h2 class="mb-4">
        <i class="bi bi-ticket-detailed"></i> Tüm Ticket'lar
    </h2>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="get" asp-action="Tickets">
            <div class="row g-3 align-items-end mb-3">
                <!-- Kategori Filtresi -->
                <div class="col-md-2">
                    <label class="form-label">Kategori</label>
                    <select name="categoryId" class="form-select" onchange="this.form.submit()">
                        <option value="">Tümü</option>
                        @foreach (var category in Model.Categories)
                        {
                            <option value="@category.Id" selected="@(Model.SelectedCategoryId == category.Id)">
                                @category.Name
                            </option>
                        }
                    </select>
                </div>

                <!-- Cevap Durumu Filtresi -->
                <div class="col-md-2">
                    <label class="form-label">Cevap Durumu</label>
                    <select name="answerStatus" class="form-select" onchange="this.form.submit()">
                        <option value="">Tümü</option>
                        <option value="answered" selected="@(Model.SelectedAnswerStatus == "answered")">
                            Cevaplandı
                        </option>
                        <option value="unanswered" selected="@(Model.SelectedAnswerStatus == "unanswered")">
                            Cevaplanmadı
                        </option>
                    </select>
                </div>

                <!-- Öncelik Filtresi -->
                <div class="col-md-2">
                    <label class="form-label">Öncelik</label>
                    <select name="priorityFilter" class="form-select" onchange="this.form.submit()">
                        <option value="">Tümü</option>
                        <option value="High" selected="@(Model.PriorityFilter == "High")">🔴 Yüksek</option>
                        <option value="Medium" selected="@(Model.PriorityFilter == "Medium")">🟡 Orta</option>
                        <option value="Low" selected="@(Model.PriorityFilter == "Low")">🟢 Düşük</option>
                    </select>
                </div>

                <!-- Arama -->
                <div class="col-md-4">
                    <label class="form-label">Arama</label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" 
                               name="searchTerm" 
                               class="form-control" 
                               placeholder="Başlık, açıklama veya kullanıcı ara..." 
                               value="@Model.SearchTerm" />
                        <button type="submit" class="btn btn-primary">Ara</button>
                    </div>
                </div>

                <!-- Filtreleri Temizle -->
                <div class="col-md-2">
                    <a asp-action="Tickets" class="btn btn-secondary w-100">
                        <i class="bi bi-arrow-clockwise"></i> Temizle
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

    <!-- Ticket Tablosu -->
    <div class="card shadow-sm">
        <div class="card-body">
            @if (Model.Tickets.Any())
            {
                <div class="table-responsive">
                <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                    <th>Öncelik</th> <!-- YENİ -->
                    <th>Başlık</th>
                    <th>Kullanıcı</th>
                    <th>Kategori</th>
                    <th>Durum</th>
                    <th>Oluşturulma Tarihi</th>
                    <th>Cevap Durumu</th>
                    <th class="text-center">İşlemler</th>
                    </tr>
                </thead>
            <tbody>
            @foreach (var ticket in Model.Tickets)
            {
                <tr class="@(ticket.AdminAnswer != null ? "table-success" : "")">
                                    <td>
                                    @if (ticket.Priority == "High")
                                    {
                                    <span class="badge bg-danger">🔴 Yüksek</span>
                                    }
                                    else if (ticket.Priority == "Medium")
                                    {
                                    <span class="badge bg-warning text-dark">🟡 Orta</span>
                                    }
                                    else
                                    {
                                    <span class="badge bg-success">🟢 Düşük</span>
                                    }
                                    </td>
            
                                    <td>
                                        <strong>@ticket.Title</strong>
                                    </td>
                                    <td>
                                        <i class="bi bi-person"></i> @ticket.User.UserName
                                    </td>
                                    <td>
                                        <span class="badge bg-info">@ticket.Category.Name</span>
                                    </td>
                                    <td>
                                        @if (ticket.Status == "Open")
                                        {
                                            <span class="badge bg-success">Açık</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Kapalı</span>
                                        }
                                    </td>
                                    <td>
                                        <small>@ticket.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                                    </td>
                                    <td>
                                        @if (ticket.AdminAnswer != null)
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle"></i> Cevaplandı
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">
                                                <i class="bi bi-clock"></i> Cevaplanmadı
                                            </span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-action="TicketDetail" asp-route-id="@ticket.Id" 
                                               class="btn btn-outline-primary" title="Detay / Cevapla">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center">
                    <h5>Ticket bulunamadı</h5>
                    <p>Seçilen filtrelere uygun ticket bulunmamaktadır.</p>
                </div>
            }
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    .table-success {
        background-color: #d1f2eb !important;
    }
</style>