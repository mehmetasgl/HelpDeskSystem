@model List<MiniHelpDesk.ViewModels.UserManagementViewModel>

@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="bi bi-people"></i> Kullanıcı Yönetimi
        </h2>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Dashboard'a Dön
        </a>
    </div>

    <!-- Filtreler -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" asp-action="Users">
                <div class="row g-3 align-items-end">
                    <!-- Arama -->
                    <div class="col-md-5">
                        <label class="form-label">Kullanıcı Ara</label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" 
                                   name="searchTerm" 
                                   class="form-control" 
                                   placeholder="Kullanıcı adı veya e-posta ara..." 
                                   value="@ViewBag.SearchTerm" />
                            <button type="submit" class="btn btn-primary">Ara</button>
                        </div>
                    </div>

                    <!-- Rol Filtresi -->
                    <div class="col-md-3">
                        <label class="form-label">Rol Filtresi</label>
                        <select name="roleFilter" class="form-select" onchange="this.form.submit()">
                            <option value="">Tüm Roller</option>
                            <option value="Admin" selected="@(ViewBag.RoleFilter == "Admin")">Admin</option>
                            <option value="User" selected="@(ViewBag.RoleFilter == "User")">User</option>
                        </select>
                    </div>

                    <!-- Filtreleri Temizle -->
                    <div class="col-md-2">
                        <a asp-action="Users" class="btn btn-secondary w-100">
                            <i class="bi bi-arrow-clockwise"></i> Temizle
                        </a>
                    </div>

                    <!-- Toplam Kullanıcı -->
                    <div class="col-md-2">
                        <div class="text-center">
                            <h4 class="text-primary mb-0">@Model.Count</h4>
                            <small class="text-muted">Toplam Kullanıcı</small>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Kullanıcı Tablosu -->
    <div class="card shadow-sm">
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Kullanıcı Adı</th>
                                <th>E-posta</th>
                                <th>Rol</th>
                                <th>Toplam Ticket</th>
                                <th>Açık Ticket</th>
                                <th class="text-center">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td>
                                        <i class="bi bi-person-circle"></i>
                                        <strong>@user.UserName</strong>
                                    </td>
                                    <td>
                                        @if (string.IsNullOrEmpty(user.Email))
                                        {
                                            <em class="text-muted">Belirtilmemiş</em>
                                        }
                                        else
                                        {
                                            @user.Email
                                        }
                                    </td>
                                    <td>
                                        @foreach (var role in user.Roles)
                                        {
                                            if (role == "Admin")
                                            {
                                                <span class="badge bg-danger">@role</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-primary">@role</span>
                                            }
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-info">@user.TotalTickets</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-success">@user.OpenTickets</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-action="UserDetails" asp-route-id="@user.Id" 
                                               class="btn btn-outline-primary" title="Detay">
                                                <i class="bi bi-eye"></i> Detay
                                            </a>
                                            @if (!user.Roles.Contains("Admin"))
                                            {
                                                <button type="button" 
                                                        class="btn btn-outline-danger" 
                                                        data-bs-toggle="modal" 
                                                        data-bs-target="#deleteModal-@user.Id"
                                                        title="Sil">
                                                    <i class="bi bi-trash"></i> Sil
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>

                                <!-- Silme Modal -->
                                <div class="modal fade" id="deleteModal-@user.Id" tabindex="-1" aria-hidden="true">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <div class="modal-header bg-danger text-white">
                                                <h5 class="modal-title">Kullanıcıyı Sil</h5>
                                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                            </div>
                                            <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post">
                                                <div class="modal-body">
                                                    <div class="alert alert-warning">
                                                        <i class="bi bi-exclamation-triangle"></i>
                                                        <strong>Uyarı!</strong> Bu işlem geri alınamaz.
                                                    </div>
                                                    <p><strong>@user.UserName</strong> kullanıcısını silmek istediğinize emin misiniz?</p>
                                                    <p class="text-muted">Kullanıcının tüm ticket'ları ve bildirimleri silinecektir.</p>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                                                    <button type="submit" class="btn btn-danger">Kullanıcıyı Sil</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center">
                    <h5>Kullanıcı bulunamadı</h5>
                    <p>Seçilen filtrelere uygun kullanıcı bulunmamaktadır.</p>
                </div>
            }
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">