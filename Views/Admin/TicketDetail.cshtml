@model MiniHelpDesk.Models.Ticket

@{
    ViewData["Title"] = "Ticket Detayı";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container mt-4">
    <div class="row">
        <!-- Ticket Bilgileri -->
        <div class="col-md-8">
            <div class="card shadow mb-4">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="bi bi-ticket-detailed"></i> @Model.Title
                    </h4>
                    @if (Model.Status == "Open")
                    {
                        <span class="badge bg-success">Açık</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Kapalı</span>
                    }
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <strong>Ticket Sahibi:</strong>
                        <span class="text-muted">
                            <i class="bi bi-person"></i> @Model.User.UserName
                        </span>
                    </div>

                    <div class="mb-3">
                        <strong>Kategori:</strong>
                        <span class="badge bg-info">@Model.Category.Name</span>
                    </div>

                    <div class="mb-3">
                        <strong>Öncelik:</strong>
                    @if (Model.Priority == "High")
                    {
                        <span class="badge bg-danger">🔴 Yüksek</span>
                    }
                    else if (Model.Priority == "Medium")
                    {
                        <span class="badge bg-warning text-dark">🟡 Orta</span>
                    }
                    else
                    {
                        <span class="badge bg-success">🟢 Düşük</span>
                    }
                    </div>
                    
                    <div class="mb-3">
                        <strong>Oluşturulma Tarihi:</strong>
                        <span class="text-muted">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>

                    @if (Model.UpdatedAt.HasValue)
                    {
                        <div class="mb-3">
                            <strong>Son Güncelleme:</strong>
                            <span class="text-muted">@Model.UpdatedAt.Value.ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                    }

                    <hr />

                    <div class="mb-3">
                        <h5>Açıklama:</h5>
                        <p class="text-muted">@Model.Description</p>
                    </div>
                </div>
            </div>

            <!-- Admin Cevabı -->
            <div class="card shadow @(Model.AdminAnswer != null ? "border-success" : "border-warning")">
                <div class="card-header @(Model.AdminAnswer != null ? "bg-success" : "bg-warning") text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-reply-fill"></i> 
                        @if (Model.AdminAnswer != null)
                        {
                            <text>Admin Cevabı (Gönderildi)</text>
                        }
                        else
                        {
                            <text>Admin Cevabı Yaz</text>
                        }
                    </h5>
                </div>
                <div class="card-body">
                    @if (Model.AdminAnswer != null)
                    {
                        <div class="mb-3">
                            <p>@Model.AdminAnswer</p>
                            @if (Model.AnsweredAt.HasValue)
                            {
                                <small class="text-muted">
                                    Cevaplanma Tarihi: @Model.AnsweredAt.Value.ToString("dd.MM.yyyy HH:mm")
                                </small>
                            }
                        </div>
                        <hr />
                        <p class="text-muted mb-0">
                            <i class="bi bi-info-circle"></i> Cevap zaten gönderilmiş. Değiştirmek isterseniz aşağıdaki formu kullanabilirsiniz.
                        </p>
                    }
                    
                    <form asp-action="AnswerTicket" method="post" class="mt-3">
                        <input type="hidden" name="id" value="@Model.Id" />
                        
                        <div class="mb-3">
                            <label class="form-label">Cevabınız</label>
                            <textarea name="adminAnswer" class="form-control" rows="6" 
                                      placeholder="Ticket'a cevabınızı buraya yazın...">@Model.AdminAnswer</textarea>
                            <small class="text-muted">Maksimum 1000 karakter</small>
                        </div>

                        <button type="submit" class="btn btn-success btn-lg w-100">
                            <i class="bi bi-send"></i> Cevabı Gönder
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Sağ: İşlem Paneli -->
        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">İşlemler</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <form asp-action="ToggleTicketStatus" asp-route-id="@Model.Id" method="post">
                            @if (Model.Status == "Open")
                            {
                                <button type="submit" class="btn btn-danger w-100">
                                    <i class="bi bi-x-circle"></i> Ticket'ı Kapat
                                </button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-success w-100">
                                    <i class="bi bi-check-circle"></i> Ticket'ı Tekrar Aç
                                </button>
                            }
                        </form>

                        <a asp-action="Tickets" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Ticket Listesine Dön
                        </a>

                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </div>
                </div>
            </div>

            <div class="card shadow mt-3">
                <div class="card-body">
                    <h6 class="card-title">Cevap Durumu</h6>
                    @if (Model.AdminAnswer != null)
                    {
                        <p class="text-success mb-0">
                            <i class="bi bi-check-circle-fill"></i> Cevaplandı
                        </p>
                    }
                    else
                    {
                        <p class="text-warning mb-0">
                            <i class="bi bi-hourglass-split"></i> Cevaplanmadı
                        </p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">