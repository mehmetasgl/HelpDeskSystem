@model MiniHelpDesk.ViewModels.CreateTicketViewModel

@{
    ViewData["Title"] = "Yeni Ticket Oluştur";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h3 class="mb-0">
                    <i class="bi bi-ticket-detailed"></i> Yeni Destek Talebi Oluştur
                </h3>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label"></label>
                        <input asp-for="Title" class="form-control" placeholder="Örn: Şifre sıfırlama sorunu" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CategoryId" class="form-label"></label>
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories">
                            <option value="">-- Kategori Seçin --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>

                    <!-- Öncelik Dropdown (YENİ) -->
                    <div class="mb-3">
                        <label asp-for="Priority" class="form-label"></label>
                        <select asp-for="Priority" class="form-select">
                            <option value="Low">🟢 Düşük</option>
                            <option value="Medium" selected>🟡 Orta</option>
                            <option value="High">🔴 Yüksek</option>
                        </select>
                        <span asp-validation-for="Priority" class="text-danger"></span>
                        <small class="text-muted">Ticket'ınızın öncelik seviyesini belirleyin</small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="6" 
                                  placeholder="Sorununuzu detaylı bir şekilde açıklayın..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                        <small class="text-muted">Maksimum 1000 karakter</small>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Geri Dön
                        </a>
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-check-circle"></i> Ticket Oluştur
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}