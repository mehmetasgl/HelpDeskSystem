@model MiniHelpDesk.Models.Ticket

@{
    ViewData["Title"] = "Ticket Detayı";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container mt-4">
    <div class="row">
        <!-- Ticket Bilgileri -->
        <div class="col-md-8">
            <div class="card shadow mb-4">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="bi bi-ticket-detailed"></i> @Model.Title
                    </h4>
                    @if (Model.Status == "Open")
                    {
                        <span class="badge bg-success">Açık</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Kapalı</span>
                    }
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <strong>Kategori:</strong>
                        <span class="badge bg-info">@Model.Category.Name</span>
                    </div>

                    <div class="mb-3">
                        <strong>Öncelik:</strong>
                    @if (Model.Priority == "High")
                    {
                       <span class="badge bg-danger">🔴 Yüksek</span>
                    }
                    else if (Model.Priority == "Medium")
                    {
                        <span class="badge bg-warning text-dark">🟡 Orta</span>
                    }
                    else
                    {
                        <span class="badge bg-success">🟢 Düşük</span>
                    }
                    </div>

                    <div class="mb-3">
                        <strong>Oluşturulma Tarihi:</strong>
                        <span class="text-muted">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>

                    @if (Model.UpdatedAt.HasValue)
                    {
                        <div class="mb-3">
                            <strong>Son Güncelleme:</strong>
                            <span class="text-muted">@Model.UpdatedAt.Value.ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                    }

                    <hr />

                    <div class="mb-3">
                        <h5>Açıklama:</h5>
                        <p class="text-muted">@Model.Description</p>
                    </div>
                </div>
            </div>

            <!-- Admin Cevabı -->
            @if (Model.AdminAnswer != null)
            {
                <div class="card shadow border-success">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-reply-fill"></i> Admin Cevabı
                        </h5>
                    </div>
                    <div class="card-body">
                        <p>@Model.AdminAnswer</p>
                        @if (Model.AnsweredAt.HasValue)
                        {
                            <small class="text-muted">
                                Cevaplanma Tarihi: @Model.AnsweredAt.Value.ToString("dd.MM.yyyy HH:mm")
                            </small>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-warning">
                    <i class="bi bi-clock"></i> Bu ticket henüz cevaplanmadı. Admin cevabını bekliyorsunuz.
                </div>
            }
        </div>

        <!-- İşlem Paneli -->
<div class="col-md-4">
    <div class="card shadow">
        <div class="card-header bg-secondary text-white">
            <h5 class="mb-0">İşlemler</h5>
        </div>
        <div class="card-body">
            <div class="d-grid gap-2">
                @if (Model.Status == "Open")
                {
                    <!-- Ticket açıksa düzenle ve kapat butonları göster -->
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                        <i class="bi bi-pencil"></i> Düzenle
                    </a>

                    <form asp-action="ToggleStatus" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn btn-danger w-100">
                            <i class="bi bi-x-circle"></i> Ticket'ı Kapat
                        </button>
                    </form>
                }
                else
                {
                    <!-- Ticket kapalıysa sadece bilgi göster -->
                    <div class="alert alert-secondary mb-0">
                        <i class="bi bi-lock"></i>
                        <strong>Ticket Kapalı</strong>
                        <p class="mb-0 mt-2 small">Kapalı ticket'lar düzenlenemez ve tekrar açılamaz. Yeni bir ticket oluşturabilirsiniz.</p>
                    </div>
                }

                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Listeye Dön
                </a>
            </div>
        </div>
    </div>

    <div class="card shadow mt-3">
        <div class="card-body">
            <h6 class="card-title">Durum Bilgisi</h6>
            @if (Model.Status == "Open")
            {
                <p class="text-success mb-2">
                    <i class="bi bi-circle-fill"></i> Açık
                </p>
            }
            else
            {
                <p class="text-secondary mb-2">
                    <i class="bi bi-x-circle-fill"></i> Kapalı
                </p>
            }
            @if (Model.AdminAnswer != null)
            {
                <p class="text-success mb-0">
                    <i class="bi bi-check-circle-fill"></i> Cevaplandı
                </p>
            }
            else
            {
                <p class="text-warning mb-0">
                    <i class="bi bi-hourglass-split"></i> Cevap Bekleniyor
                </p>
            }
        </div>
    </div>
</div>

            <!-- Bilgi Kartı -->
            <div class="card shadow mt-3">
                <div class="card-body">
                    <h6 class="card-title">Durum Bilgisi</h6>
                    @if (Model.AdminAnswer != null)
                    {
                        <p class="text-success mb-0">
                            <i class="bi bi-check-circle-fill"></i> Cevaplandı
                        </p>
                    }
                    else
                    {
                        <p class="text-warning mb-0">
                            <i class="bi bi-hourglass-split"></i> Cevap Bekleniyor
                        </p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">